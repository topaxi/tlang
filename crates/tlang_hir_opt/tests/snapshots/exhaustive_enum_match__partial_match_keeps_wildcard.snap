expression: pretty
---
enum Color {
    Red
    Green
    Blue
}
fn name(color: Color) -> String {
    match color {
        Color::Red => {
            "red"
        },
        Color::Green => {
            "green"
        },
        _ => {
            "fallback"
        },
    }
}
