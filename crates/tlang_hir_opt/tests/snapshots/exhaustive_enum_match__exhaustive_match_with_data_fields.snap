expression: pretty
---
enum Shape {
    Circle {
        0: f64,
    }
    Rect {
        0: f64,
        1: f64,
    }
}
fn area(shape: Shape) -> unknown {
    match shape {
        Shape::Circle { 0: r } => {
            r
        },
        Shape::Rect { 0: w, 1: h } => {
            (w * h)
        },
    }
}
