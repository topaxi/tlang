expression: pretty
---
enum Num {
    V {
        0: i64,
    }
    W
}
fn classify(num: Num) -> String {
    match num {
        Num::V { 0: 0 } => {
            "zero"
        },
        Num::W => {
            "w"
        },
        _ => {
            "other"
        },
    }
}
