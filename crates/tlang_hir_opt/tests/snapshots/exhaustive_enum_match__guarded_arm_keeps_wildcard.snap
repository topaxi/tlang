source: crates/tlang_hir_opt/tests/exhaustive_enum_match.rs
expression: pretty
---
enum Light {
    On
    Off
}
fn describe(light: Light) -> unknown {
    match light {
        Light::On => {
            "on"
        },
        Light::Off if (1 == 0) => {
            "off (impossible)"
        },
        _ => {
            "fallback"
        },
    }
}
