pub enum Option {
  Some(value),
  None,
}

pub fn Option.is_some(Option::Some(_)) { true }
pub fn Option.is_some(_) { false }

pub fn Option.is_none(Option::None) { true }
pub fn Option.is_none(_) { false }

pub fn Option.unwrap(Option::Some(x)) { x }
pub fn Option.unwrap(_) { panic("Called unwrap on None") }
