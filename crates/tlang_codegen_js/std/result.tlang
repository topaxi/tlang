pub enum Result<T, E> {
  Ok(T),
  Err(E),
}

pub fn Result.is_ok(Result::Ok(_)) { true }
pub fn Result.is_ok(_) { false }

pub fn Result.is_err(Result::Err(_)) { true }
pub fn Result.is_err(_) { false }

pub fn Result.unwrap(Result::Ok(x)) { x }
pub fn Result.unwrap(_) { panic("Called unwrap on Err") }
