// Hello World — write to stdout using the stream API
//
// Run: cargo run --bin octarine -- crates/tlang_octarine/examples/hello_stream.tlang
//
// Demonstrates:
//   • Streams::stdout() factory
//   • WriteStream.write() method
//   • WriteStream.flush() method

let out = Streams::stdout();

out.write("Hello from octarine!\n");
out.flush();
