fn range(start: i64, end: i64) -> List<i64> { range_acc(start, end, []) }

fn range_acc(start: i64, end: i64, acc: List<i64>) -> List<i64> {
    if start >= end {
        acc
    } else {
        rec range_acc(start + 1, end, [...acc, start])
    }
}

fn foldl([]: List<i64>, acc: i64, _: fn(i64, i64) -> i64) -> i64 { acc }
fn foldl([x, ...xs]: List<i64>, acc: i64, f: fn(i64, i64) -> i64) -> i64 { rec foldl(xs, f(acc, x), f) }

fn add(acc: i64, x: i64) -> i64 { acc + x }

range(0, 10000)
|> foldl(0, add)
|> log();
