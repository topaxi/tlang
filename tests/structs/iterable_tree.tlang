// Iterable Binary Search Tree
// Demonstrates implementing the Iterable protocol for a custom data structure.
// In-order traversal yields BST values in sorted order.

enum Tree {
    Empty,
    Node { value: isize, left: Tree, right: Tree },
}

fn insert(Tree::Empty, value) {
    Tree::Node { value: value, left: Tree::Empty, right: Tree::Empty }
}
fn insert(Tree::Node { value: node_val, left, right }, value) {
    if value < node_val {
        Tree::Node { value: node_val, left: insert(left, value), right }
    } else if value > node_val {
        Tree::Node { value: node_val, left, right: insert(right, value) }
    } else {
        Tree::Node { value: node_val, left, right }
    }
}

// In-order traversal: left subtree, root, right subtree
fn to_list(Tree::Empty) { [] }
fn to_list(Tree::Node { value, left, right }) {
    [...to_list(left), value, ...to_list(right)]
}

// Make Tree iterable by delegating to the built-in List iterator
impl Iterable for Tree {
    fn iter(tree) {
        Iterable::iter(to_list(tree))
    }
}

// Build a BST
let tree = Tree::Empty
    |> insert(5)
    |> insert(3)
    |> insert(7)
    |> insert(1)
    |> insert(4)
    |> insert(6)
    |> insert(2);

// Iterate: in-order traversal yields sorted values
log("Sorted values:");
for x in tree {
    log(x);
};

// Sum all values using for-loop accumulator
let total = for x in tree; with sum = 0 {
    sum + x
};
log("Sum:");
log(total);

// Collect even values
let evens = for x in tree; with acc = [] {
    if x % 2 == 0 { [...acc, x] } else { acc }
};
log("Even values:");
log(evens);
