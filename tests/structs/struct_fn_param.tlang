struct SafeHtml { value: string }

// Single-dispatch with struct destructuring in function parameter
fn get_value(SafeHtml { value }) { value }

let sh = SafeHtml { value: "hello" };
get_value(sh) |> log();

struct Point { x: isize, y: isize }

fn get_x(Point { x, y: _ }) { x }
fn get_sum(Point { x, y }) { x + y }

let p = Point { x: 3, y: 4 };
get_x(p) |> log();
get_sum(p) |> log();

fn describe(value) {
    match value {
        SafeHtml { value } => "html: " + value,
        _ => "unknown",
    }
}

describe(sh) |> log();
describe(42) |> log();
