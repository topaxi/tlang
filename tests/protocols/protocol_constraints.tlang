protocol PartialEq {
  fn eq(self, other)
}

protocol Eq : PartialEq {}

protocol Ord : Eq {
  fn cmp(self, other)
}

struct Point { x: isize, y: isize }

impl PartialEq for Point {
  fn eq(self, other) {
    self.x == other.x && self.y == other.y
  }
}

impl Eq for Point {}

impl Ord for Point {
  fn cmp(self, other) {
    if self.x < other.x { -1 }
    else if self.x > other.x { 1 }
    else { 0 }
  }
}

let a = Point { x: 1, y: 2 };
let b = Point { x: 1, y: 2 };
let c = Point { x: 3, y: 4 };

PartialEq::eq(a, b) |> log();
PartialEq::eq(a, c) |> log();
Ord::cmp(a, c) |> log();
Ord::cmp(c, a) |> log();
