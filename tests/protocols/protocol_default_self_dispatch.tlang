// Tests implicit self-dispatch in protocol default implementations.
// `self.foldl(...)` inside the default bodies of `sum` and `length` are
// automatically rewritten to `Foldable::foldl(self, ...)` by the compiler.
protocol Foldable {
  fn foldl(self, init, f)
  fn sum(self) { self.foldl(0, fn (acc, x) { acc + x }) }
  fn length(self) { self.foldl(0, fn (acc, _) { acc + 1 }) }
}

enum List {
  Nil,
  Cons(unknown, List),
}

impl Foldable for List {
  fn foldl(List::Nil, acc, _) { acc }
  fn foldl(List::Cons(head, tail), acc, f) {
    rec foldl(tail, f(acc, head), f)
  }
}

let xs = List::Cons(1, List::Cons(2, List::Cons(3, List::Nil)));
Foldable::sum(xs) |> log();
Foldable::length(xs) |> log();
Foldable::foldl(xs, 0, fn (acc, x) { acc + x }) |> log();

