let increment: fn(i64) -> i64 = fn (x: i64) -> i64 { x + 1 };
let square: fn(i64) -> i64 = fn (x: i64) -> i64 { x ** 2 };
let times_ten: fn(i64) -> i64 = fn (x: i64) -> i64 { x * 10 };

// Test Functor::map on List
let squares: List<i64> = Functor::map([1, 2, 3], square);
squares |> log();

// Test backward compat: global map still works
map([4, 5, 6], times_ten) |> log();
