// Test Functor::map on Option
let some = Option::Some(5);
Functor::map(some, fn (x) { x * 2 }) |> log();

let none = Option::None;
Functor::map(none, fn (x) { x * 2 }) |> log();

// Test Functor::map on Result
let ok = Result::Ok(10);
Functor::map(ok, fn (x) { x + 1 }) |> log();

let err = Result::Err("error");
Functor::map(err, fn (x) { x + 1 }) |> log();

// Test Functor::map on List
Functor::map([1, 2, 3], fn (x) { x ** 2 }) |> log();

// Test backward compat: global map still works
map([4, 5, 6], fn (x) { x * 10 }) |> log();
