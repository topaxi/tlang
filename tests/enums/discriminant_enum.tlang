enum HttpStatus {
    Ok = 200,
    Created = 201,
    BadRequest = 400,
    NotFound = 404,
    InternalServerError = 500,
}

fn describe(HttpStatus::Ok) { "OK" }
fn describe(HttpStatus::Created) { "Created" }
fn describe(HttpStatus::BadRequest) { "Bad Request" }
fn describe(HttpStatus::NotFound) { "Not Found" }
fn describe(HttpStatus::InternalServerError) { "Internal Server Error" }

log(HttpStatus::Ok);
log(HttpStatus::NotFound);
log(describe(HttpStatus::Ok));
log(describe(HttpStatus::Created));
log(describe(HttpStatus::NotFound));
log(describe(HttpStatus::InternalServerError));
