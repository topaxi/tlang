// Regex tagged string literals
// Demonstrates: re"..." syntax for regular expressions

fn test_basic() {
    re"foo|bar".test("foo") |> log();
    re"foo|bar".test("bar") |> log();
    re"foo|bar".test("baz") |> log();
}

fn test_case_insensitive() {
    re"hello".test("Hello World") |> log();
}

fn test_exec() {
    let result = re"(\d+)".exec("abc123def");
    match result {
        Option::Some(m) => log(m),
        Option::None => log("no match"),
    }
    let no_match = re"\d+".exec("no digits here");
    match no_match {
        Option::Some(m) => log(m),
        Option::None => log("no match"),
    }
}

fn test_replace() {
    re"\s+".replace_all("hello   world", " ") |> log();
}

fn test_stringify() {
    re"foo|bar".flags("gi") |> log();
}

fn test_match_operator() {
    // =~ returns true when the pattern matches
    log("foo" =~ re"foo|bar");
    log("baz" =~ re"foo|bar");
    // !~ is the negation
    log("foo" !~ re"foo|bar");
    log("baz" !~ re"foo|bar");
    // case-insensitive flag
    log("Hello" =~ re"hello".flags("i"));
}

test_basic();
test_case_insensitive();
test_exec();
test_replace();
test_stringify();
test_match_operator();
