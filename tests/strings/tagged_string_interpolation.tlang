// Tagged string interpolation tests
// Demonstrates: re"...{expr}..." syntax with full expression interpolation

fn test_basic_interpolation() {
    let prefix = "foo";
    let postfix = "bar";
    let pattern = re"{prefix}|{postfix}";
    pattern.test("foo") |> log();
    pattern.test("bar") |> log();
    pattern.test("baz") |> log();
}

fn test_no_interpolation() {
    // No interpolation - just static parts
    re"\d+".test("123") |> log();
    re"\d+".test("abc") |> log();
}

fn test_regex_quantifier_not_interpolation() {
    // {2,5} should be treated as regex quantifier, not interpolation
    re"\d{2,5}".test("123") |> log();
    re"\d{2,5}".test("1") |> log();
}

fn test_escaped_braces() {
    // Double braces produce literal braces
    re"\d{{1,3}}".test("12") |> log();
}

fn test_expression_interpolation() {
    let a = "hello";
    let b = "world";
    re"{a}_{b}".test("hello_world") |> log();
    re"{a}_{b}".test("foo_bar") |> log();
}

test_basic_interpolation();
test_no_interpolation();
test_regex_quantifier_not_interpolation();
test_escaped_braces();
test_expression_interpolation();
