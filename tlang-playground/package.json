{
  "name": "tlang-playground",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "tsc",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test:e2e": "CI=1 playwright test",
    "pretest:e2e:webserver": "test -d dist || npm run build",
    "test:e2e:webserver": "node e2e/serve.js"
  },
  "sideEffects": [
    "src/components/**/*"
  ],
  "browserslist": [
    "last 2 firefox versions",
    "last 2 and_ff versions",
    "last 2 safari versions",
    "last 2 ios_saf versions",
    "last 2 chrome versions",
    "last 2 and_chr versions"
  ],
  "dependencies": {
    "@catppuccin/palette": "^1.8.0",
    "@codemirror/lang-javascript": "^6.2.5",
    "@floating-ui/dom": "^1.7.6",
    "@lit/context": "^1.1.6",
    "codemirror": "^6.0.2",
    "codemirror-lang-tlang": "file:../packages/codemirror-lang-tlang",
    "codemirror-theme-catppuccin": "^0.3.0",
    "lit": "3.3.2",
    "lz-string": "^1.5.0",
    "tlang_bindings_js": "file:../crates/tlang_bindings_js/pkg"
  },
  "devDependencies": {
    "@jackolope/ts-lit-plugin": "^3.1.6",
    "@playwright/test": "^1.58.2",
    "vite": "^8.0.0",
    "vite-plugin-wasm": "^3.6.0"
  }
}
