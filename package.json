{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "@tlang/repo",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "scripts": {
    "assume-unchanged": "git update-index --assume-unchanged crates/tlang_bindings_js/pkg/package.json",
    "predev": "npm run build:bindings_js:dev",
    "dev": "npm run dev -w tlang-playground",
    "prebuild": "npm run assume-unchanged",
    "prebuild:bindings_js:dev": "npm run assume-unchanged",
    "prebuild:bindings_js:release": "npm run assume-unchanged",
    "prebuild:playground": "npm run build:bindings_js:release",
    "build:bindings_js:dev": "wasm-pack build --dev --target web crates/tlang_bindings_js",
    "build:bindings_js:release": "wasm-pack build --target web crates/tlang_bindings_js",
    "build:playground": "npm run build -w tlang-playground",
    "build": "npm run build:playground",
    "prepreview": "npm run build",
    "preview": "npx serve tlang-playground/dist",
    "lint": "eslint && stylelint \"**/*.css\" \"**/components/**/*.ts\"",
    "lint:fix": "eslint --fix && stylelint \"**/*.css\" \"**/components/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "test:e2e": "npm run test:e2e -w tlang-playground"
  },
  "workspaces": [
    "packages/*",
    "tree-sitter-tlang",
    "tlang-playground"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "postcss-lit": "^1.4.1",
    "prettier": "^3.8.1",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.1"
  },
  "packageManager": "npm@11.4.2",
  "engines": {
    "node": "24.0.2",
    "npm": "11.4.2"
  },
  "volta": {
    "node": "24.0.2",
    "npm": "11.4.2"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2"
  }
}
