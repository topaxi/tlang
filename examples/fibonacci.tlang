// fibonacci(isize) -> isize
fn fibonacci(n) { fibonacci(n, 0, 1) }
// fibonacci(0, isize, isize) -> isize
fn fibonacci(0, a, _) { a }
// fibonacci(1, isize, isize) -> isize
fn fibonacci(1, _, b) { b }
// fibonacci(isize, isize, isize) -> isize
fn fibonacci(n, a, b) { rec fibonacci(n - 1, b, a + b) }

fibonacci(50)
|> log();
